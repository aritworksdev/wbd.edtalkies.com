AIBOARD_APP_ENV=development
AIBOARD_FULLSCREEN=true
AIBOARD_EXPORT_DIR=~/AiBoard/exports
AIBOARD_LOG_LEVEL=INFO

# Leave the base URL blank to use the built-in mock response.
EDTALKIES_API_BASE_URL=
EDTALKIES_API_KEY=
EDTALKIES_AI_QUERY_PATH=/api/ai/query
EDTALKIES_OCR_PATH=/api/ocr/handwriting
EDTALKIES_TIMEOUT_SECONDS=30
EDTALKIES_RETRY_COUNT=2
EDTALKIES_MODEL=default
EDTALKIES_ASSISTANT_MODE=teacher_board
EDTALKIES_SCHOOL_ID=
EDTALKIES_BOARD_ID=
EDTALKIES_DEVICE_ID=
EDTALKIES_SESSION_ID=

# Recognition provider: local (real offline TrOCR), edtalkies, or mock.
AIBOARD_HANDWRITING_PROVIDER=local
AIBOARD_LOCAL_HANDWRITING_MODEL=microsoft/trocr-base-handwritten

# Exit behavior: quit, shutdown, or reboot. Shutdown/reboot always require
# the in-app confirmation when AIBOARD_CONFIRM_EXIT=true.
AIBOARD_EXIT_ACTION=quit
AIBOARD_CONFIRM_EXIT=true
